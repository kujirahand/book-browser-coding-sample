{
  "manifest_version": 3,
  "name": "Dynamic Ad Blocker",
  "version": "1.0.0",
  "description": "APIサーバーから取得したルールを動的に登録する広告ブロッカー",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dynamic Ad Blocker"
  }
}
