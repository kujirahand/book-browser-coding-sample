{
  "manifest_version": 3,
  "name": "アイデアバンク",
  "version": "0.1.0",
  "description": "選択テキストをアイデアとして保存する拡張機能",
  "permissions": ["contextMenus", "activeTab", "notifications", "tabs"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "アイデアバンク",
    "default_icon": {
      "128": "icon128.png"
    },
    "default_popup": "popup.html"
  }
}
